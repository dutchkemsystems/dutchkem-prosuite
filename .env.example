# .env.example — Commit this file to git
# Copy to .env.local and fill with actual values (NEVER commit .env or .env.local)

# ═══════════════════════════════════════════
# REQUIRED — Application will not start without these
# ═══════════════════════════════════════════

# ── Backend Server ──
JWT_SECRET=your-64-char-random-secret-here

# ── Dashboard URL (defaults to Vercel production) ──
# DASHBOARD_URL=https://your-domain.com/admin/dashboard

# ── AWS Configuration (for OTP SMS) ──
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_REGION=us-east-1
AWS_SNS_FROM_EMAIL=your-email@example.com

# ── Convex (required) ──
VITE_CONVEX_URL=https://your-project.convex.cloud
CONVEX_SITE_URL=https://your-project.convex.site
CONVEX_DEPLOYMENT=your-deployment-name

# ── JWT Secrets (min 32 chars each, generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))") ──
JWT_SECRET_CLIENT=
JWT_SECRET_ADMIN=
REFRESH_SECRET=

# ── Payment: Kora Pay (required for subscriptions) ──
KORA_PUBLIC_KEY=
KORA_SECRET_KEY=
KORA_ENCRYPTION_KEY=
KORA_PAY_WEBHOOK_SECRET=

# ── AI Providers (required for all agents) ──
NVIDIA_NIM_API_KEY=
OPENROUTER_API_KEY=

# ── Termii SMS (required for OTP) ──
# DND Channel: Sends OTP via DND channel (bypasses Do Not Disturb)
# Sender ID: N-Alert (API-only, not visible in Termii dashboard)
TERMII_API_KEY=
TERMII_SECRET=
TERMII_SENDER_ID=N-Alert
TERMII_CHANNEL=dnd

# ═══════════════════════════════════════════
# REQUIRED FOR SPECIFIC FEATURES
# ═══════════════════════════════════════════

# ── Direct Social OAuth (per-platform credentials) ──
# OPTIONAL when COMPOSIO_API_KEY is set (Composio is PRIMARY)

# Composio (PRIMARY — one key handles 11 platforms: X, LinkedIn, FB, IG, TikTok, YT, Pinterest, Reddit, Threads, Discord, Bluesky)
# Get a free key at https://app.composio.dev — 20k calls/month free, 1k connected accounts
COMPOSIO_API_KEY=

# X (Twitter)
X_CLIENT_ID=
X_CLIENT_SECRET=

# LinkedIn
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# Facebook / Instagram
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# TikTok
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=

# YouTube (Google)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Pinterest
PINTEREST_APP_ID=
PINTEREST_APP_SECRET=

# Reddit
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# Threads
THREADS_APP_ID=
THREADS_APP_SECRET=

# Discord
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# App URL (for OAuth callbacks)
APP_URL=https://prosuite.dutchkemventures.com

# ── Email (required for password reset / alerts) ──
RESEND_API_KEY=
FROM_EMAIL=security@dutchkem.com
ALERT_EMAIL=admin@dutchkem.com

# ═══════════════════════════════════════════
# AUTH MIGRATION (parallel-run phase config)
# ═══════════════════════════════════════════

AUTH_MIGRATION_PHASE=dual_write_log_only
AUTH_MIGRATION_ADMIN_KEY=
AUTH_TEST_WHITELIST=
AUTH_MIGRATION_LOG_DIR=./logs
NEW_AUTH_ENABLED=true
NEW_AUTH_WHITELIST=

# ═══════════════════════════════════════════
# SERVER CONFIG
# ═══════════════════════════════════════════

PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:5173,http://localhost:3000
SESSION_TIMEOUT_MINUTES=120
ADMIN_SESSION_TIMEOUT_MINUTES=30
MAX_CONCURRENT_SESSIONS=3
MAX_ADMIN_CONCURRENT_SESSIONS=1
ADMIN_2FA_REQUIRED=true
2FA_ISSUER_NAME=DutchkemProsuite

# ── Rate Limiting ──
LOGIN_RATE_LIMIT_WINDOW=15
LOGIN_RATE_LIMIT_MAX_ATTEMPTS=5
ADMIN_LOGIN_RATE_LIMIT_MAX=3

# ── Lockout Config ──
FAILED_LOGIN_LOCKOUT_MINUTES=30
MAX_FAILED_ATTEMPTS=10

# ── IP Whitelist (CIDR notation, comma-separated) ──
ADMIN_IP_WHITELIST=

# ═══════════════════════════════════════════
# OPTIONAL — Monitoring & Storage
# ═══════════════════════════════════════════

SENTRY_DSN=
SLACK_WEBHOOK_URL=
REDIS_URL=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
CLOUD_STORAGE_KEY=

# ═══════════════════════════════════════════
# ENCRYPTION (AES-256-GCM for payouts)
# ═══════════════════════════════════════════

ENCRYPTION_KEY=

# ═══════════════════════════════════════════
# DAILY SWEEP (encrypted destination override)
# ═══════════════════════════════════════════

DAILY_SWEEP_ACCOUNT_NUMBER_ENCRYPTED=
DAILY_SWEEP_ACCOUNT_NAME_ENCRYPTED=
DAILY_SWEEP_BANK_CODE=
DAILY_SWEEP_BANK_NAME=
DAILY_SWEEP_IV=
DAILY_SWEEP_TAG=

# ═══════════════════════════════════════════
# GOOGLE OAUTH
# ═══════════════════════════════════════════

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://dutchkem-api.onrender.com/auth/google/callback

# ═══════════════════════════════════════════
# CHARITY / TITHE DEDUCTION SYSTEM
# ═══════════════════════════════════════════

CHARITY_ENABLED=true
CHARITY_MONTHLY_PERCENT=10
CHARITY_BANK_CODE=999999
CHARITY_ACCOUNT_NUMBER=8121161202
CHARITY_ACCOUNT_NAME=Oladotun Alabi
CHARITY_AUTO_TRANSFER_DAY=last
CHARITY_AUTO_TRANSFER_TIME=23:59

# ═══════════════════════════════════════════
# PHASE 2: PUSH NOTIFICATIONS (VAPID Keys)
# ═══════════════════════════════════════════
# Generate VAPID keys with: npx web-push generate-vapid-keys
# Or run: node -e "const webpush = require('web-push'); console.log(webpush.generateVAPIDKeys())"

VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:admin@dutchkemventures.com

# Client-side VAPID key (same as VAPID_PUBLIC_KEY, used in browser)
VITE_VAPID_PUBLIC_KEY=
